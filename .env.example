# Environment Name
NODE_ENV=development

# Server Configuration
PORT=5000
CORS_ORIGIN=*

# Database
# Example: postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public

# Admin Seed Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=secureadminpassword

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_access_key_here
JWT_ACCESS_EXPIRES_IN=1d
JWT_RESET_SECRET=your_super_secret_reset_key_here
JWT_RESET_EXPIRES_IN=15m

# SMTP Configuration (Nodemailer)
# You can use Ethereal Email for testing: https://ethereal.email/
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com